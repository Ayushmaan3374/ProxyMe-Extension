{
  "manifest_version": 3,
  "name": "ProxyMe Meeting Assistant",
  "version": "2.1",
  "description": "Listen for trigger names in meetings and query backend AI.",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
  "https://proxymeagent.onrender.com/*"
],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://meet.google.com/*"],
      "js": ["content.js"]
    }
  ]
}